DATABASE_URL=postgres://postgres:postgres@localhost:5432/elohim_sms
RUST_LOG=info
BIND_ADDRESS=0.0.0.0:3000
JSON_LOGS=false

# Глобальный мастер API-ключ (опционально).
# Если не задан, backend принимает только ключи, созданные через Telegram-бота.
API_KEY=

# Внутренний токен между backend и Telegram-ботом (должен совпадать с INTERNAL_BOT_TOKEN бота)
INTERNAL_BOT_TOKEN=change_me_to_random_long_string

# URL сервиса бота для внутренних уведомлений (например, http://localhost:8080)
BOT_INTERNAL_URL=http://localhost:8080

# SMS-провайдеры. Можно настроить несколько; сообщения отправляются через первого успешного.
# Поддерживается тип: devil-traff.
# Провайдеры перебираются по возрастанию PRIORITY (меньше = раньше).
SMS_PROVIDER_1_NAME=devil-traff-main
SMS_PROVIDER_1_TYPE=devil-traff
SMS_PROVIDER_1_URL=https://api.devil-traff.cc
SMS_PROVIDER_1_AUTH_TOKEN=your_devil_traff_jwt_token
SMS_PROVIDER_1_ROUTE=Auto
SMS_PROVIDER_1_SENDER_ID=ElohimSMS
SMS_PROVIDER_1_PRIORITY=1

# Резервный провайдер (раскомментируйте при необходимости):
# SMS_PROVIDER_2_NAME=devil-traff-reserve
# SMS_PROVIDER_2_TYPE=devil-traff
# SMS_PROVIDER_2_URL=https://api.devil-traff.cc
# SMS_PROVIDER_2_AUTH_TOKEN=your_reserve_devil_traff_jwt_token
# SMS_PROVIDER_2_ROUTE=Auto
# SMS_PROVIDER_2_SENDER_ID=ElohimSMS
# SMS_PROVIDER_2_PRIORITY=2

# SkyTelecom (раскомментируйте при необходимости):
# SMS_PROVIDER_3_NAME=skytelecom
# SMS_PROVIDER_3_TYPE=skytelecom
# SMS_PROVIDER_3_URL=https://skytelecom.io
# SMS_PROVIDER_3_API_KEY=your_skytelecom_api_key
# SMS_PROVIDER_3_PRIORITY=3

# Устаревший формат конфигурации (всё ещё работает как fallback-совместимость):
# SMS_GATEWAY_URL=https://api.devil-traff.cc
# SMS_GATEWAY_AUTH_TOKEN=your_devil_traff_jwt_token
# SMS_GATEWAY_ROUTE=Auto
# SMS_GATEWAY_SENDER_ID=ElohimSMS
