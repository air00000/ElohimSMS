DATABASE_URL=postgres://postgres:postgres@localhost:5432/elohim_sms
RUST_LOG=info
BIND_ADDRESS=0.0.0.0:3000
JSON_LOGS=false

# Внутренний токен для общения Telegram-бота с API
INTERNAL_BOT_TOKEN=change_me_to_random_long_string

# SMS-шлюз Devil-Traff (https://api.devil-traff.cc)
SMS_GATEWAY_URL=https://api.devil-traff.cc
SMS_GATEWAY_AUTH_TOKEN=your_devil_traff_jwt_token
SMS_GATEWAY_ROUTE=Auto
SMS_GATEWAY_SENDER_ID=ElohimSMS

# Сайт с капчей (внешний домен)
CAPTCHA_SITE_URL=https://your-captcha-site.com

# Google reCAPTCHA v2
RECAPTCHA_SECRET=your_recaptcha_secret
RECAPTCHA_SITE_KEY=your_recaptcha_site_key
