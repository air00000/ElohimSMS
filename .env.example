# Telegram-бот
BOT_TOKEN=your_telegram_bot_token_from_botfather
OWNER_TELEGRAM_ID=123456789
OWNER_USERNAME=your_username

# Внутренний токен между ботом и backend (должен совпадать у обоих сервисов)
INTERNAL_BOT_TOKEN=change_me_to_random_long_string

# Режим работы бота: polling или webhook
BOT_MODE=polling

# Настройки webhook (только при BOT_MODE=webhook)
WEBHOOK_URL=https://your-domain.com
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/webhook

# PostgreSQL (локальный кластер на порту 5433)
DATABASE_URL=postgres://postgres@localhost:5433/elohim_sms

# Backend: глобальный мастер API-ключ (опционально).
# Если не задан, backend принимает только ключи, созданные через Telegram-бота.
API_KEY=

# URL сервиса бота для внутренних уведомлений (например, http://bot:8080)
BOT_INTERNAL_URL=http://bot:8080

# Базовый URL для коротких ссылок. Если не задан, используется CAPTCHA_SITE_URL.
# SHORT_LINK_BASE_URL=https://linkre.info

# Настройки сайта-прокладки с капчей (captcha_site_example/index.html).
CAPTCHA_SITE_URL=https://linkre.info
RECAPTCHA_SECRET=6LfDoUgtAAAAANDMIHg5sBXdTHW73rXCC-TZoTcw
RECAPTCHA_SITE_KEY=6LfDoUgtAAAAAN5xibYYHlrZvVuQ5B3vqNt0f8wI

# Префикс пути для коротких ссылок (должен совпадать с настройками фронтенда).
# По умолчанию: l, т.е. ссылки будут https://linkre.info/l/xxxx
LINK_PATH_PREFIX=l

# SMS-провайдеры. Сообщения отправляются через первого успешного.
# Провайдеры перебираются по возрастанию PRIORITY (меньше = раньше).
# Поддерживаемые типы: devil-traff, limitlesstxt, skytelecom, smsmobile.
# Devil-Traff, SkyTelecom и LimitlessTXT используют API-ключ/токен.
# SMSMobile.cc требует логин/пароль (в их API нет API-key).
SMS_PROVIDER_1_NAME=devil-traff-main
SMS_PROVIDER_1_TYPE=devil-traff
SMS_PROVIDER_1_URL=https://api.devil-traff.cc
SMS_PROVIDER_1_AUTH_TOKEN=your_devil_traff_jwt_token
SMS_PROVIDER_1_ROUTE=Auto
SMS_PROVIDER_1_SENDER_ID=ElohimSMS
SMS_PROVIDER_1_PRIORITY=1

# SMSMobile.cc (раскомментируйте при необходимости):
# SMS_PROVIDER_2_NAME=smsmobile
# SMS_PROVIDER_2_TYPE=smsmobile
# SMS_PROVIDER_2_URL=https://smsmobile.cc
# SMS_PROVIDER_2_USERNAME=your_smsmobile_username
# SMS_PROVIDER_2_PASSWORD=your_smsmobile_password
# SMS_PROVIDER_2_ROUTE_ID=route-2
# SMS_PROVIDER_2_SENDER_ID=ElohimSMS
# SMS_PROVIDER_2_PRIORITY=2

# SkyTelecom (раскомментируйте при необходимости):
# SMS_PROVIDER_3_NAME=skytelecom
# SMS_PROVIDER_3_TYPE=skytelecom
# SMS_PROVIDER_3_URL=https://skytelecom.io
# SMS_PROVIDER_3_API_KEY=your_skytelecom_api_key
# SMS_PROVIDER_3_SENDER_ID=ElohimSMS
# SMS_PROVIDER_3_PRIORITY=3

# LimitlessTXT (раскомментируйте при необходимости):
# SMS_PROVIDER_4_NAME=limitlesstxt
# SMS_PROVIDER_4_TYPE=limitlesstxt
# SMS_PROVIDER_4_URL=https://api.limitlesstxt.com
# SMS_PROVIDER_4_API_KEY=ltxt_xxxxxxxxxxxxxxxx
# SMS_PROVIDER_4_SENDER_ID=ElohimSMS
# SMS_PROVIDER_4_ROUTE=1
# SMS_PROVIDER_4_PRIORITY=4

# Логирование backend
JSON_LOGS=false
