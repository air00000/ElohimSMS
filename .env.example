# Telegram-бот
BOT_TOKEN=your_telegram_bot_token_from_botfather
OWNER_TELEGRAM_ID=123456789
OWNER_USERNAME=your_username

# Внутренний токен между ботом и backend (нужен боту, backend больше не использует)
INTERNAL_BOT_TOKEN=change_me_to_random_long_string

# Режим работы бота: polling или webhook
BOT_MODE=polling

# Настройки webhook (только при BOT_MODE=webhook)
WEBHOOK_URL=https://your-domain.com
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8080
WEBHOOK_PATH=/webhook

# PostgreSQL (локальный кластер на порту 5433)
DATABASE_URL=postgres://postgres@localhost:5433/elohim_sms

# Backend: глобальный мастер API-ключ (опционально).
# Если не задан, backend принимает только ключи, созданные через Telegram-бота.
API_KEY=

# Внутренний токен между backend и Telegram-ботом (должен совпадать с INTERNAL_BOT_TOKEN бота)
INTERNAL_BOT_TOKEN=change_me_to_random_long_string

# URL сервиса бота для внутренних уведомлений (например, http://bot:8080)
BOT_INTERNAL_URL=http://bot:8080

# SMS-шлюз Devil-Traff (https://api.devil-traff.cc)
SMS_GATEWAY_URL=https://api.devil-traff.cc
SMS_GATEWAY_AUTH_TOKEN=your_devil_traff_jwt_token
SMS_GATEWAY_ROUTE=Auto
SMS_GATEWAY_SENDER_ID=ElohimSMS

# Логирование backend
JSON_LOGS=false
